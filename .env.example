# ============================================================
# MedicToros — Configuración Firebase
# ============================================================
# 1. Copia este archivo:  cp .env.example .env
# 2. Reemplaza los valores con los de Firebase Console
# 3. Reinicia el servidor: npm run dev
# ============================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=medictoros.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=medictoros
VITE_FIREBASE_STORAGE_BUCKET=medictoros.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
