# ============================================================
# MedicToros — Configuración
# ============================================================

# --- Firebase (Spark gratis: metadatos en Firestore) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=medictoros.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=medictoros
VITE_FIREBASE_STORAGE_BUCKET=medictoros.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Supabase (GRATIS: PDFs — recomendado proyecto escolar) ---
# 1. https://supabase.com → New project (free, sin tarjeta)
# 2. Settings → API → copia Project URL y anon public key
# 3. Storage → New bucket → nombre: medicotoros-pdfs → Public bucket: ON
# 4. SQL Editor → pega y ejecuta supabase/storage-policies.sql
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=medictoros-pdfs

# Contraseña editorial para subir/eliminar (opcional)
VITE_UPLOAD_PASSWORD=

# Solo desarrollo local con emuladores Firebase (opcional)
VITE_USE_FIREBASE_EMULATORS=false

# --- Solo si usas Firebase Storage de pago (Blaze) en lugar de Supabase ---
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
UPLOAD_PASSWORD=
